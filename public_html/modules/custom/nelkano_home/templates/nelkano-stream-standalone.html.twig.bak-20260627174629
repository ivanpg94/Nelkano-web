<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Nelkano Stream</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="{{ logo_url }}" type="image/png">
    {% include '@nelkano_home/nelkano-theme-init.html.twig' %}
    <link rel="stylesheet" href="{{ base_css_url }}">
    <link rel="stylesheet" href="{{ header_css_url }}">
    <link rel="stylesheet" href="{{ footer_css_url }}">
    <link rel="stylesheet" href="{{ stream_css_url }}">
    {# Future color-mode toggle script. <script defer src="{{ theme_js_url }}"></script> #}
    {% include '@nelkano_home/nelkano-analytics.html.twig' %}
    <script defer src="{{ stream_js_url }}"></script>
  </head>
  <body>
    {% include '@nelkano_home/nelkano-header.html.twig' %}
    <main class="nk-stream" data-stream-ws-url="{{ stream_ws_url }}" data-stream-active-url="{{ stream_active_url }}" data-stream-frame-url="/api/nelkano/stream/frame" data-stream-audio-url="/api/nelkano/stream/audio" data-stream-ice-config-url="{{ stream_ice_config_url }}" data-stream-ice-servers="{{ stream_ice_servers }}" data-stream-ice-policy="{{ stream_ice_policy }}">
      <section class="nk-stream-layout">
        <div class="nk-viewer">
          <video id="stream-video" autoplay muted playsinline controls></video>
          <img id="stream-fallback-frame" alt="Emision de Android por HTTP" hidden>
          <button class="nk-viewer-fullscreen" type="button" data-stream-fullscreen aria-label="Pantalla completa">⛶</button>
          <div class="nk-video-empty" data-video-empty>
            <span>Esperando video</span>
          </div>
        </div>

        <aside class="nk-panel" aria-labelledby="stream-title">
          <p class="nk-eyebrow">Receptor WebRTC</p>
          <h1 id="stream-title">Ver una emision de Android</h1>
          <p class="nk-copy" data-stream-copy>Abre Nelkano en Android con tu cuenta, entra en el juego y pulsa Streaming. Esta pagina conectara automaticamente cuando detecte tu emision activa.</p>

          <div class="nk-stream-hint" data-stream-hint>
            Abre el emulador en Android y pulsa Streaming.
          </div>

          <button class="nk-button nk-stream-audio" type="button" data-stream-audio disabled>Activar sonido</button>
          <label class="nk-stream-volume">
            <span>Volumen</span>
            <input type="range" min="0" max="100" value="100" data-stream-volume>
          </label>
          <button class="nk-button nk-stream-disconnect" type="button" data-stream-disconnect>Desconectar</button>

          <form class="nk-stream-form nk-stream-form-hidden" data-stream-form>
            <label>
              Codigo de sesion
              <input name="sessionId" autocomplete="off" inputmode="latin" placeholder="ABC123" maxlength="12">
            </label>
            <label>
              PIN
              <input name="pin" autocomplete="one-time-code" inputmode="numeric" placeholder="1234" maxlength="8">
            </label>
            <div class="nk-actions">
              <button class="nk-button nk-primary" type="submit">Conectar manualmente</button>
            </div>
          </form>

          <dl class="nk-status">
            <div><dt>Estado</dt><dd data-stream-state>Sin conectar</dd></div>
            <div><dt>Sesion</dt><dd data-stream-session>Buscando tu emision activa</dd></div>
            <div><dt>Signaling</dt><dd data-stream-url>{{ stream_ws_url }}</dd></div>
          </dl>
        </aside>
      </section>

      <section class="nk-log" aria-label="Registro de conexion">
        <h2>Registro</h2>
        <ol data-stream-log></ol>
      </section>
    </main>
    {% include '@nelkano_home/nelkano-footer.html.twig' %}
    {% include '@nelkano_home/nelkano-consent-banner.html.twig' %}
    <script defer src="{{ base_js_url }}"></script>
  </body>
</html>
