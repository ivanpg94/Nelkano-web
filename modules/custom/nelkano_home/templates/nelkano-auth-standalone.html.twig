<!doctype html>
<html lang="{{ language|default('es') }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }} - Nelkano</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="{{ logo_url }}" type="image/png">
    {% include '@nelkano_home/nelkano-theme-init.html.twig' %}
    <link rel="stylesheet" href="{{ base_css_url }}">
    <link rel="stylesheet" href="{{ header_css_url }}">
    <link rel="stylesheet" href="{{ footer_css_url }}">
    <link rel="stylesheet" href="{{ auth_css_url }}">
    {# Future color-mode toggle script. <script defer src="{{ theme_js_url }}"></script> #}
    {% include '@nelkano_home/nelkano-analytics.html.twig' %}
  </head>
  <body>
    {% include '@nelkano_home/nelkano-header.html.twig' %}
    <main class="nk-auth-page nk-auth-{{ mode }}">
      <div class="nk-auth-layout">
        <section class="nk-auth-brand">
          <p class="nk-auth-kicker">{{ eyebrow }}</p>
          <h1>{{ auth_title }}</h1>
          <p>{{ subtitle }}</p>
          <ul class="nk-auth-points" aria-label="{{ language == 'en' ? 'Account benefits' : 'Ventajas de la cuenta' }}">
            {% for point in auth_points %}
              <li>{{ point }}</li>
            {% endfor %}
          </ul>
        </section>

        <section class="nk-auth-card" aria-label="{{ page_title }}">
          <div class="nk-auth-card-head">
            <span>{{ form_kicker }}</span>
            <h2>{{ page_title }}</h2>
          </div>
          {{ messages|raw }}
          {{ form|raw }}
        </section>
      </div>
    </main>
    {% include '@nelkano_home/nelkano-footer.html.twig' %}
    {% include '@nelkano_home/nelkano-consent-banner.html.twig' %}
    <script defer src="{{ base_js_url }}"></script>
  </body>
</html>
